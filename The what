-- Hyper Click Loop (0.05s)
task.spawn(function()
    while true do
        if Active and (tick() - SpawnTime > 3) then
            pcall(function()
                local CenterX, CenterY = Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2
                VIM:SendMouseButtonEvent(CenterX, CenterY, 0, true, game, 0)
                task.wait(0.01)
