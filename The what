-- Check for Rainbow Aura
local function HasRainbowAura(player)
    if not player.Character then return false end
    for _, v in pairs(player.Character:GetDescendants()) do
        -- เช็ค Highlight, Particle หรือชื่อที่มีคำว่า Rainbow
        if v:IsA("Highlight") or v:IsA("SelectionBox") or v:IsA("ParticleEmitter") then
            if string.find(string.lower(v.Name), "rainbow") then
                return true
            end
        end
    end
    return false
end

-- Target Filter
local function GetValidTargets()
    local ValidTargets = {}
    for _, v in pairs(Players:GetPlayers()) do
        if v ~= LocalPlayer and not LocalPlayer:IsFriendsWith(v.UserId) then
            if v.Character and v.Character:FindFirstChild("Humanoid") and v.Character:FindFirstChild("HumanoidRootPart") then
                local TRoot = v.Character.HumanoidRootPart
                local Head = v.Character:FindFirstChild("Head")
                
                -- เงื่อนไข: ไม่ล่องหน + ไม่สูงเกินพิกัด + ไม่ใช่สายรุ้ง
                if (Head and Head.Transparency <= 0.5) and TRoot.Position.Y <= MaxTargetHeight then
                    if not HasRainbowAura(v) then
                        table.insert(ValidTargets, v)
                    end
                end
            end
        end
    end
    return ValidTargets
end

-- Server Hopper
local function HopServer()
    pcall(function()
        local servers = HttpService:JSONDecode(game:HttpGet("https://games.roblox.com/v1/games/" .. game.PlaceId .. "/servers/Public?sortOrder=Desc&limit=100")).data
        for _, v in ipairs(servers) do
            if v.playing < v.maxPlayers and v.id ~= game.JobId then
                TeleportService:TeleportToPlaceInstance(game.PlaceId, v.id)
                break
            end
        end
    end)
end

task.spawn(function()
    while task.wait(5) do
        if Active and #GetValidTargets() < 1 then HopServer() end
    end
end)

-- Core Engine
RunService.Heartbeat:Connect(function()
    local Char = LocalPlayer.Character
    if not Char or not Char:FindFirstChild("HumanoidRootPart") then return end
    local Root = Char.HumanoidRootPart
    local TimeDiff = tick() - SpawnTime

    if Active then
        -- Disable Collision while Active
        for _, part in pairs(Char:GetDescendants()) do
            if part:IsA("BasePart") then part.CanCollide = false end
        end

        if TimeDiff < 3 then
            Root.CFrame = StrategyPos
            Root.Velocity = Vector3.zero
            return 
        end

        local targets = GetValidTargets()
        local BestTarget = nil
        local MinHP = math.huge
        
        for _, t in pairs(targets) do
            -- เช็คซ้ำอีกรอบ ถ้าตอนล็อคอยู่แล้วเขาเปิดออร่าสีรุ้ง ให้หลุดทันที
            if not HasRainbowAura(t) and t.Character.Humanoid.Health < MinHP then
                MinHP = t.Character.Humanoid.Health
                BestTarget = t
            end
        end

        if BestTarget then
            local TRoot = BestTarget.Character.HumanoidRootPart
            Root.CFrame = CFrame.new(TRoot.Position + Vector3.new(0, -3.5, 0)) * CFrame.Angles(math.rad(90), 0, 0)
            Root.Velocity = Vector3.zero
        else
            Root.Velocity = Vector3.zero
        end
    end
end)

