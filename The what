-- Reset Function (Walk Normal)
local function FullReset()
    Active = false
    KillBtn.Text = "AUTO KILL: OFF"
    KillBtn.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
    UserInputService.MouseIconEnabled = true
    
    if LocalPlayer.Character then
        local Root = LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
        if Root then Root.Velocity = Vector3.zero end
        
        for _, v in pairs(LocalPlayer.Character:GetDescendants()) do
            if v:IsA("BasePart") then
                v.CanCollide = true -- คืนค่าให้เดินได้ปกติ
            end
        end
    end
end

KillBtn.MouseButton1Click:Connect(function()
    Active = not Active
    if Active then
        KillBtn.Text = "AUTO KILL: ON"
        KillBtn.BackgroundColor3 = Color3.fromRGB(200, 0, 0)
        UserInputService.MouseIconEnabled = false 
    else
        FullReset()
    end
end)

