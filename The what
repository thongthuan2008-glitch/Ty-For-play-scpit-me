-- Check if someone is already targeting this player
local function IsTargetOccupied(target)
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p ~= target and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
            local dist = (p.Character.HumanoidRootPart.Position - (target.Character.HumanoidRootPart.Position + Vector3.new(0, -3.5, 0))).Magnitude
            if dist < 2 then -- ถ้ามีใครอยู่ห่างจากจุดวาร์ปใต้ตีนไม่เกิน 2 หน่วย ถือว่าโดนแย่งแล้ว
                return true
            end
        end
    end
    return false
end

-- Target Finder (Anti-Friend & Anti-Steal)
local function GetValidTargets()
    local ValidTargets = {}
    for _, v in pairs(Players:GetPlayers()) do
        if v ~= LocalPlayer and not LocalPlayer:IsFriendsWith(v.UserId) then
            if v.Character and v.Character:FindFirstChild("Humanoid") and v.Character:FindFirstChild("HumanoidRootPart") then
                local TRoot = v.Character.HumanoidRootPart
                local Head = v.Character:FindFirstChild("Head")
                local IsInvis = (Head and Head.Transparency > 0.5) 
                
                -- เงื่อนไข: ไม่โปร่งใส + ไม่สูงเกินพิกัด + เลือด > 0 + ไม่มีคนอื่นจองอยู่
                if not IsInvis and TRoot.Position.Y <= MaxTargetHeight and v.Character.Humanoid.Health > 0 then
                    if not IsTargetOccupied(v) then
                        table.insert(ValidTargets, v)
                    end
                end
            end
        end
    end
    return ValidTargets
end

-- Server Check
task.spawn(function()
    while task.wait(5) do
        if Active and #GetValidTargets() < 1 then HopServer() end
    end
end)

-- Core Engine
RunService.Heartbeat:Connect(function()
    local Char = LocalPlayer.Character
    if not Char or not Char:FindFirstChild("HumanoidRootPart") then return end
    local Root = Char.HumanoidRootPart
    local TimeDiff = tick() - SpawnTime

    if Active then
        for _, part in pairs(Char:GetDescendants()) do
            if part:IsA("BasePart") then part.CanCollide = false end
        end

        if TimeDiff < 3 then
            Root.CFrame = StrategyPos
            Root.Velocity = Vector3.zero
            return 
        end

        local targets = GetValidTargets()
        local BestTarget = nil
        local MinHP = math.huge
        
        for _, t in pairs(targets) do
            if t.Character.Humanoid.Health < MinHP then
                MinHP = t.Character.Humanoid.Health
                BestTarget = t
            end
        end

        if BestTarget then
            local TRoot = BestTarget.Character.HumanoidRootPart
            Root.CFrame = CFrame.new(TRoot.Position + Vector3.new(0, -3.5, 0)) * CFrame.Angles(math.rad(90), 0, 0)
            Root.Velocity = Vector3.zero
        end
    end
end)

